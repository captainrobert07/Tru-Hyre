# Tru Hyre — environment configuration
# Copy this file to .env.local for local dev. Vercel injects these in production.

# --- Auth.js v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-string
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# --- Database (Vercel Postgres / Neon) ---
# Vercel auto-injects these on deploy. For local dev, paste from your Postgres provider.
POSTGRES_URL=postgres://user:password@host:5432/db
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# --- Vercel Blob (resume + packet storage) ---
# Get from Vercel dashboard -> Storage -> Blob -> .env.local tab
BLOB_READ_WRITE_TOKEN=

# --- Email (Resend) ---
# Optional. Without these, the app logs emails to the console in dev.
RESEND_API_KEY=
EMAIL_FROM="Tru Hyre <noreply@truhyre.app>"

# --- App branding ---
NEXT_PUBLIC_APP_NAME="Tru Hyre"
NEXT_PUBLIC_APP_TAGLINE="An Allianz HR Platform - Project by Kris"
