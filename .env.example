# Tru Hyre — environment configuration
# Copy this file to .env and fill in values for your local setup.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# In production set DEBUG=False and add your domain(s) to ALLOWED_HOSTS, e.g.
# DJANGO_ALLOWED_HOSTS=tru-hyre.example.com,.onrender.com,.up.railway.app
# .vercel.app is auto-added when running on Vercel.

# --- Database ---
# Leave DATABASE_URL blank to use SQLite at db.sqlite3 (default for local dev).
# For Postgres:  postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# --- Email ---
# For dev, leave EMAIL_BACKEND blank — emails print to the console.
# Set to "smtp" with the EMAIL_* values for real SMTP delivery.
EMAIL_BACKEND=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Tru Hyre <noreply@truhyre.app>

# --- File storage ---
# "local" stores files under media/. "s3" requires AWS_* below (future).
FILE_STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# --- Branding ---
SITE_NAME=Tru Hyre
SITE_TAGLINE=An Allianz HR Platform - Project by Kris
