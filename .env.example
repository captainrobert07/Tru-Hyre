# Tru Hyre — environment configuration
# Copy this file to .env.local for local dev. Vercel injects these in production.

# --- Auth.js v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-string
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# --- Database (Vercel Postgres / Neon) ---
# Vercel auto-injects these on deploy. For local dev, paste from your Postgres provider.
POSTGRES_URL=postgres://user:password@host:5432/db
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# --- Google Drive (resume + packet storage) ---
# Service-account JSON, base64-encoded so newlines survive .env parsing.
# Generate with: cat sa-key.json | base64 -w0
GOOGLE_SERVICE_ACCOUNT_JSON=
# Drive folder ID, manually shared with the service account as Editor.
# (Folder URL: https://drive.google.com/drive/folders/<this-id>)
GDRIVE_RESUMES_FOLDER_ID=

# --- Email (Gmail SMTP via shared HR mailbox) ---
# 16-char App Password generated by Workspace admin (requires 2FA on the mailbox).
# Without these, the app logs emails to the console in dev.
GMAIL_USER=recruitment@example.com
GMAIL_APP_PASSWORD=
EMAIL_FROM="Tru Hyre Recruitment <recruitment@example.com>"

# --- App branding ---
NEXT_PUBLIC_APP_NAME="Tru Hyre"
NEXT_PUBLIC_APP_TAGLINE="An Allianz HR Platform - Project by Kris"
